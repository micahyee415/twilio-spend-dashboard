# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit the real file.

# Twilio credentials
# TWILIO_ACCOUNT_SID: your master account SID (Console → Account Info)
# TWILIO_API_KEY_SID / TWILIO_API_KEY_SECRET: scoped API key (Console → API keys & tokens)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret_here

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# NextAuth — run: openssl rand -base64 32   to generate the secret
NEXTAUTH_SECRET=your_random_secret_here
# Local dev URL — Vercel sets this automatically in production
NEXTAUTH_URL=http://localhost:3000
